# ===========================================
# Database Configuration
# ===========================================
POSTGRES_USER=bitly
POSTGRES_PASSWORD=bitly_secret
POSTGRES_DB=bitly

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://redis:6379/0

# ===========================================
# ClickHouse Configuration
# ===========================================
CLICKHOUSE_USER=bitly
CLICKHOUSE_PASSWORD=bitly_secret
CLICKHOUSE_DB=analytics

# ===========================================
# Kafka Configuration
# ===========================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# ===========================================
# OAuth Configuration (Google)
# ===========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# AWS S3 Configuration
# ===========================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=bitly-qr-images
AWS_REGION=us-east-1

# ===========================================
# NextAuth Configuration
# ===========================================
NEXTAUTH_URL=http://localhost
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# ===========================================
# Application Configuration
# ===========================================
SHORT_DOMAIN=http://localhost/r
# Optional: set to an existing user email to assign admin role on RBAC startup
# SEED_ADMIN_EMAIL=admin@example.com
